# Cooked Service — environment variables
# Copy to .env and fill in real values. Never commit .env.

# ── Spring ────────────────────────────────────────────
# Leave empty (or set to "prod") so the dev profile is not loaded.
SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8082

# ── Database ──────────────────────────────────────────
CUSTOM_DB_URL=jdbc:postgresql://<host>:5432/cooked
CUSTOM_DB_USER=cooked_user
CUSTOM_DB_PASS=
# Used by docker-compose for the Postgres superuser.
DB_PASSWORD=

# ── Security ──────────────────────────────────────────
# Must be at least 32 characters.
JWT_SECRET=
# Token TTL in milliseconds (default: 86400000 = 24 h).
JWT_EXPIRATION_MS=86400000

# ── JPA logging (disable in prod) ────────────────────
JPA_SHOW_SQL=false
JPA_FORMAT_SQL=false